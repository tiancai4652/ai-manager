{
  "_说明": "这是提醒功能的示例配置文件。使用前请复制到项目根目录并重命名为 reminders.json",
  "_用法": "cp config/reminders.json.example reminders.json",

  "version": 1,

  "reminders": [
    {
      "id": "rmd_example_daily",
      "message": "该喝水了！保持健康饮水习惯",
      "time": "2026-06-04T09:00:00.000Z",
      "repeat": "daily",
      "enabled": true,
      "createdAt": "2026-06-04T00:00:00.000Z",
      "updatedAt": "2026-06-04T00:00:00.000Z"
    },
    {
      "id": "rmd_example_weekly",
      "message": "每周例会提醒",
      "time": "2026-06-08T10:00:00.000Z",
      "repeat": "weekly",
      "enabled": true,
      "createdAt": "2026-06-04T00:00:00.000Z",
      "updatedAt": "2026-06-04T00:00:00.000Z"
    },
    {
      "id": "rmd_example_once",
      "message": "下午 3 点提交周报",
      "time": "2026-06-05T15:00:00.000Z",
      "repeat": "none",
      "enabled": true,
      "createdAt": "2026-06-04T00:00:00.000Z",
      "updatedAt": "2026-06-04T00:00:00.000Z"
    },
    {
      "id": "rmd_example_workdays",
      "message": "站会开始！",
      "time": "2026-06-04T09:30:00.000Z",
      "repeat": "weekdays",
      "enabled": false,
      "createdAt": "2026-06-04T00:00:00.000Z",
      "updatedAt": "2026-06-04T00:00:00.000Z"
    },
    {
      "id": "rmd_example_cron",
      "message": "每 30 分钟休息一下眼睛",
      "time": "2026-06-04T08:00:00.000Z",
      "repeat": "0,30 * * * 1-5",
      "enabled": true,
      "createdAt": "2026-06-04T00:00:00.000Z",
      "updatedAt": "2026-06-04T00:00:00.000Z"
    }
  ],

  "_字段说明": {
    "version": "配置文件格式版本，当前为 1",
    "reminders": "提醒列表数组",
    "reminders[].id": "唯一标识符，添加时自动生成",
    "reminders[].message": "提醒内容文本",
    "reminders[].time": "提醒触发时间，ISO 8601 格式（如 2026-06-05T09:00:00.000Z）",
    "reminders[].repeat": "重复规则，可选值见下方说明",
    "reminders[].enabled": "是否启用，true/false",
    "reminders[].createdAt": "创建时间，自动生成",
    "reminders[].updatedAt": "最后更新时间，自动生成"
  },

  "_repeat可选值": {
    "none": "不重复（单次提醒，触发后自动销毁）",
    "daily": "每天固定时间",
    "weekly": "每周同一天固定时间",
    "monthly": "每月同一天固定时间",
    "yearly": "每年同月同日固定时间",
    "weekdays": "工作日（周一至周五）",
    "自定义cron": "标准 5 段 cron 表达式，如 '0,30 9-17 * * 1-5' 表示工作日 9-17 点每半小时"
  }
}
